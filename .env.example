# ── Frontend build-time environment variables ─────────────────────────────────
# Copy to .env.local for local development. Never commit .env.local.
#
# In production this file is NOT used — VITE_API_URL is passed directly
# to `npm run build` in deploy.sh (empty string = same origin, which is
# correct because nginx proxies /api/* to the Node backend).

# URL of the API server, WITHOUT a trailing slash.
#   Production (same-origin via nginx):  leave empty or omit entirely
#   Local dev (backend on port 3001):    http://localhost:3001
VITE_API_URL=http://localhost:3001
