# ── Tickerdle API server — environment variables ──────────────────────────────
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# On the VPS:  cp server/.env.example server/.env  then edit server/.env

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on.
# nginx proxies /api/* → http://127.0.0.1:$PORT  (keep 3001 unless you change nginx.conf)
PORT=3001

# Set to "production" on the VPS; "development" locally
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────

# Origin(s) allowed to call the API.
# Production:   your apex domain, no trailing slash
# Development:  http://localhost:5173  (Vite dev server default)
CORS_ORIGIN=https://tickerdle.org

# ── Rate limiting (optional overrides) ───────────────────────────────────────
# The defaults in src/index.js (60 req/min general, 20 req/min for /evaluate)
# are sensible for a hobby game. Uncomment to override.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60
# EVALUATE_LIMIT_MAX=20
